# ПОДГОТОВКА EXCEL-ТАБЛИЦЫ
# =========================================================

def convert_numeric_columns(df: pd.DataFrame, cols: list[str]) -> pd.DataFrame:
    """
    Приводит перечисленные колонки к числовому типу.
    """
    out = df.copy()
    for col in cols:
        out[col] = to_numeric_series(out[col])
    return out


def convert_percent_columns(df: pd.DataFrame, cols: list[str]) -> pd.DataFrame:
    """
    Конвертирует проценты из формата 32.16 в 0.3216.
    """
    out = df.copy()
    for col in cols:
        out[col] = to_numeric_series(out[col]) / 100
    return out


def add_basic_flags(df: pd.DataFrame) -> pd.DataFrame:
    """
    Добавляет базовые флаги:
    - FLAG_POS_IN_BUFFER_300M
    - FLAG_POLYGON_IN_BUFFER_300M
    - FLAG_DIST_M_GT_0
    """
    out = df.copy()

    out["FLAG_POS_IN_BUFFER_300M"] = np.where(out["POS_COUNT_ALL"].fillna(0) > 0, 1, 0)
    out["FLAG_POLYGON_IN_BUFFER_300M"] = np.where(out["polygon_count"].fillna(0) > 0, 1, 0)

    out["DIST_M_NUM"] = to_numeric_series(out["DIST_M"])
    out["FLAG_DIST_M_GT_0"] = np.where(out["DIST_M_NUM"].fillna(0) > 0, 1, 0)

    return out


def add_max_quality_category(df: pd.DataFrame) -> pd.DataFrame:
    """
    Определяет категорию качества с максимальным значением
    среди DEEP_INDOOR / IN_CAR / INDOOR / OUTDOOR.

    Результат:
    - MAX_QUALITY_COL
    """
    out = df.copy()

    quality_cols = ["DEEP_INDOOR", "IN_CAR", "INDOOR", "OUTDOOR"]
    quality_num_cols = []

    for col in quality_cols:
        num_col = f"{col}_NUM"
        out[num_col] = to_numeric_series(out[col])
        quality_num_cols.append(num_col)

    out["MAX_QUALITY_COL"] = out[quality_num_cols].idxmax(axis=1).str.replace("_NUM", "", regex=False)

    quality_name_map = {
        "DEEP_INDOOR": "Deep Indoor",
        "IN_CAR": "In Car",
        "INDOOR": "Indoor",
        "OUTDOOR": "Outdoor"
    }

    out["MAX_QUALITY_COL"] = out["MAX_QUALITY_COL"].map(quality_name_map)

    mask_all_null = out[quality_num_cols].isna().all(axis=1)
    out.loc[mask_all_null, "MAX_QUALITY_COL"] = np.nan

    return out


def make_share_category(series: pd.Series) -> pd.Series:
    """
    Разбивает долю на интервалы по 5%.
    Пример:
    0.321 -> '30% - 35%'

    Если значение отсутствует:
    'Не определенно'
    """
    s = to_numeric_series(series)
    pct = s * 100

    lower = np.floor(pct / 5) * 5
    lower = lower.clip(0, 95)

    upper = (lower + 5).clip(5, 100)

    result = (
        lower.astype("Int64").astype(str)
        + "% - " +
        upper.astype("Int64").astype(str)
        + "%"
    )

    return result.where(s.notna(), "Не определенно")


def add_share_categories(df: pd.DataFrame) -> pd.DataFrame:
    """
    Добавляет категориальные интервалы по долям рынка.
    """
    out = df.copy()

    share_cols = [
        "MSH_HOME_LOC_4",
        "MSH_WORK_LOC_4",
        "MSH_EXTRAIN_LOC_4",
        "MARKET_SHARE_LOC_4"
    ]

    for col in share_cols:
        out[f"{col}_CAT_5"] = make_share_category(out[col])

    return out


def add_prevailing_operator(df: pd.DataFrame) -> pd.DataFrame:
    """
    Определяет превалирующего оператора:
    - в тайле
    - в соседних тайлах

    Результаты:
    - PREV_OPERATOR_TILE
    - PREV_OPERATOR_NEIB
    """
    out = df.copy()

    operator_cols_tile = ["MGF_MSH", "BIL_MSH", "T2_MSH", "OTH_MSH", "MTS_MSH"]
    operator_cols_neib = ["MGF_MSH_NEIB", "BIL_MSH_NEIB", "T2_MSH_NEIB", "OTH_MSH_NEIB", "MTS_MSH_NEIB"]

    for col in operator_cols_tile + operator_cols_neib:
        out[f"{col}_NUM"] = to_numeric_series(out[col]).fillna(0)

    operator_name_map = {
        "MGF_MSH_NUM": "Мегафон",
        "BIL_MSH_NUM": "Билайн",
        "T2_MSH_NUM": "T2",
        "OTH_MSH_NUM": "Другие",
        "MTS_MSH_NUM": "МТС",
        "MGF_MSH_NEIB_NUM": "Мегафон",
        "BIL_MSH_NEIB_NUM": "Билайн",
        "T2_MSH_NEIB_NUM": "T2",
        "OTH_MSH_NEIB_NUM": "Другие",
        "MTS_MSH_NEIB_NUM": "МТС"
    }

    tile_num_cols = [f"{col}_NUM" for col in operator_cols_tile]
    neib_num_cols = [f"{col}_NUM" for col in operator_cols_neib]

    out["PREV_OPERATOR_TILE"] = out[tile_num_cols].idxmax(axis=1).map(operator_name_map)
    out["PREV_OPERATOR_NEIB"] = out[neib_num_cols].idxmax(axis=1).map(operator_name_map)

    mask_tile_zero = out[tile_num_cols].sum(axis=1) == 0
    mask_neib_zero = out[neib_num_cols].sum(axis=1) == 0

    out.loc[mask_tile_zero, "PREV_OPERATOR_TILE"] = "Не определенно"
    out.loc[mask_neib_zero, "PREV_OPERATOR_NEIB"] = "Не определенно"

    return out


def fill_zero_columns(df: pd.DataFrame, cols: list[str]) -> pd.DataFrame:
    """
    Заполняет пустые/NaN значения нулями в указанных колонках.
    """
    out = df.copy()
    for col in cols:
        out[col] = to_numeric_series(out[col]).fillna(0)
    return out


def build_excel_dataset(
    gdf_poi: gpd.GeoDataFrame,
    df_cat: pd.DataFrame
) -> pd.DataFrame:
    """
    Готовит финальный DataFrame для Excel:
    - добавляет русские названия категорий
    - приводит числовые поля
    - добавляет флаги и производные признаки
    - удаляет ненужные колонки
    """
    df = gdf_poi.copy()

    df["Категория RU"] = df["TAG"].map(df_cat.set_index("category_en")["category_ru"])
    df["Категория RU"] = df["Категория RU"].fillna("Неизвестная категория")

    numeric_columns = [
        "HOME_SUBS_LOC_4",
        "WORK_SUBS_LOC_4",
        "ENTRTAIN_SUBS_LOC_4",
        "SUBS_CNT_PREV_LOC_4",
    ]

    percent_columns = ["DEEP_INDOOR", "IN_CAR", "INDOOR", "OUTDOOR"]

    columns_to_drop = [
        "POS_COUNT_NOT_SELL_Federal",
        "POS_COUNT_NOT_SELL_Local",
        "POS_COUNT_NOT_SELL_Monobrand",
        "POS_COUNT_NOT_SELL_On_line",
        "POS_COUNT_SELL_Federal",
        "POS_COUNT_SELL_Local",
        "POS_COUNT_SELL_Monobrand",
        "POS_COUNT_SELL_On_line",
        "BUFFER",
        "LOC_ID_4",
        "geometry",
        "MACROREGION_NAME",
        "REGION_NAME_POI",
        "LOCATION_ID",
        "LEVEL_MSK",
        "ADMIN_REGION_ID",
        "TAG",
        "GI_CNT_90_Federal",
        "GI_CNT_90_Local",
        "GI_CNT_90_Monobrand",
        "GI_CNT_90_On_line",
        "REPORT_DATE",
        "REGION_NAME",
        "LOC_NAME_4",
        "MACROREGION_ID",
    ]

    fill_zero_cols = [
        "HOME_SUBS_LOC_4",
        "MSH_WORK_LOC_4",
        "WORK_SUBS_LOC_4",
        "MSH_EXTRAIN_LOC_4",
        "ENTRTAIN_SUBS_LOC_4",
        "MARKET_SHARE_LOC_4",
        "SUBS_CNT_PREV_LOC_4"
    ]

    df = convert_numeric_columns(df, numeric_columns)
    df = convert_percent_columns(df, percent_columns)
    df = df.drop(columns=columns_to_drop, errors="ignore")
    df = add_basic_flags(df)
    df = add_max_quality_category(df)
    df = add_share_categories(df)
    df = add_prevailing_operator(df)
    df = fill_zero_columns(df, fill_zero_cols)

    temp_cols = (
        ["DIST_M_NUM"] +
        [f"{col}_NUM" for col in ["DEEP_INDOOR", "IN_CAR", "INDOOR", "OUTDOOR"]] +
        [f"{col}_NUM" for col in ["MGF_MSH", "BIL_MSH", "T2_MSH", "OTH_MSH", "MTS_MSH"]] +
        [f"{col}_NUM" for col in ["MGF_MSH_NEIB", "BIL_MSH_NEIB", "T2_MSH_NEIB", "OTH_MSH_NEIB", "MTS_MSH_NEIB"]]
    )

    df.drop(columns=temp_cols, inplace=True, errors="ignore")

    return df

def add_region_msk_column(df: pd.DataFrame, level_col: str = "LEVEL_MSC") -> pd.DataFrame:
    """
    Добавляет колонку REGION_MSK:
    - 1/2/3 -> Москва
    - 4 -> Московская Область
    """
    out = df.copy()
    level_series = out[level_col].astype(str)

    out["REGION_MSK"] = np.where(
        level_series.isin(["1", "2", "3", "1,0", "2,0", "3,0"]),
        "Москва",
        np.where(
            level_series.isin(["4", "4,0"]),
            "Московская Область",
            None
        )
    )

    return out

gdf_msh_poi_pos_excel_mo = build_excel_dataset(
    gdf_poi=gdf_msh_poi_pos_mo,
    df_cat=df_cat
)

gdf_msh_poi_pos_excel_msk = build_excel_dataset(
    gdf_poi=gdf_msh_poi_pos_msk,
    df_cat=df_cat
)

df_result_mo_msk = pd.concat([gdf_msh_poi_pos_excel_msk, gdf_msh_poi_pos_excel_mo], axis=0)
df_result_mo_msk = add_region_msk_column(df_result_mo_msk)


def export_txt_and_refresh_excel_sources(
    gdf_msh_poi_pos_excel: pd.DataFrame,
    df_pos_filtered: pd.DataFrame,
    path_oper_mr: str,
    folder_txt_out: str = "Исходники",
    file_txt_poi: str = "POI",
    file_txt_pos: str = "POS",
    file_ext: str = ".txt",
    file_exlsx_upd: str = "Адресная_програма_POI.xlsx",
    sep_for_txt: str = ";",
    encod_for_txt: str = "utf-8",
    decimal_for_txt: str = ",",
    visible_excel: bool = False,
    sleep_seconds: float = 1.0,
):
    """
    1. Выгружает POI.txt и POS.txt
    2. Открывает уже существующий Excel-файл
    3. Обновляет в нем внешние TXT-источники
    4. Сохраняет Excel-файл на месте

    Важно:
    - path_oper_mr должен уже указывать на конечную рабочую папку проекта
    - Excel-файл должен уже существовать
    - В нем уже должны быть настроены подключения к TXT
    """
    base_dir = Path(path_oper_mr)
    txt_dir = base_dir / folder_txt_out
    txt_dir.mkdir(parents=True, exist_ok=True)

    output_path_poi = txt_dir / f"{file_txt_poi}{file_ext}"
    output_path_pos = txt_dir / f"{file_txt_pos}{file_ext}"
    output_path_poi_pos_excel = base_dir / file_exlsx_upd

    # 1. Выгрузка TXT
    gdf_msh_poi_pos_excel.to_csv(
        output_path_poi,
        sep=sep_for_txt,
        decimal=decimal_for_txt,
        encoding=encod_for_txt,
        index=False
    )

    df_pos_filtered.to_csv(
        output_path_pos,
        sep=sep_for_txt,
        decimal=decimal_for_txt,
        encoding=encod_for_txt,
        index=False
    )

    print(f"Файл POI выгружен: {output_path_poi}")
    print(f"Файл POS выгружен: {output_path_pos}")

    if not output_path_poi_pos_excel.exists():
        raise FileNotFoundError(f"Excel-файл не найден: {output_path_poi_pos_excel}")

    # 2. Обновление Excel-источников
    try:
        import win32com.client as win32
    except ImportError as e:
        raise ImportError(
            "Не найден модуль win32com. Установи pywin32: python -m pip install pywin32"
        ) from e

    excel = None
    wb = None

    try:
        excel = win32.DispatchEx("Excel.Application")
        excel.Visible = visible_excel
        excel.DisplayAlerts = False
        excel.AskToUpdateLinks = False

        wb = excel.Workbooks.Open(
            str(output_path_poi_pos_excel),
            UpdateLinks=0,
            ReadOnly=False,
            IgnoreReadOnlyRecommended=True,
            AddToMru=False,
            Local=True,
            CorruptLoad=1
        )

        # Обновляем все внешние подключения / запросы / сводные, завязанные на источники
        wb.RefreshAll()

        # Ждем завершения асинхронных запросов
        try:
            excel.CalculateUntilAsyncQueriesDone()
        except Exception:
            pass

        # Дополнительное ожидание на случай медленных подключений
        time.sleep(sleep_seconds)

        wb.Save()

        print(f"Excel-файл обновлен: {output_path_poi_pos_excel}")

    finally:
        if wb is not None:
            try:
                wb.Close(SaveChanges=True)
            except Exception:
                pass

        if excel is not None:
            try:
                excel.Quit()
            except Exception:
                pass

    return (
        str(output_path_poi),
        str(output_path_pos),
        str(output_path_poi_pos_excel)
    )

output_path_poi, output_path_pos, output_path_poi_pos_excel = export_txt_and_refresh_excel_sources(
    gdf_msh_poi_pos_excel=df_result_mo_msk,
    df_pos_filtered=df_pos_filtered,
    path_oper_mr=path_oper_mr,
    folder_txt_out=folder_txt_out,
    file_txt_poi=file_txt_poi,
    file_txt_pos=file_txt_pos,
    file_ext=file_ext,
    file_exlsx_upd=file_xlsx_upd,
    sep_for_txt=sep_for_txt,
    encod_for_txt=encod_for_txt,
    decimal_for_txt=decimal_for_txt,
    visible_excel=False,
    sleep_seconds=2
)

