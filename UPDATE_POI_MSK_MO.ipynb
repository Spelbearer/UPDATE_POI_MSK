def fill_metric_columns(df: pd.DataFrame, prefixes: tuple[str, ...]) -> pd.DataFrame:
    """
    Заполняет NaN нулями во всех колонках, имена которых начинаются с одного из prefixes.
    """
    out = df.copy()
    metric_cols = [col for col in out.columns if str(col).startswith(prefixes)]
    for col in metric_cols:
        out[col] = out[col].fillna(0).astype(int)
    return out

def pivot_sum_by_channel(
    df: pd.DataFrame,
    value_col: str,
    prefix: str,
    row_id_col: str = "POI_ROW_ID",
    channel_col: str = "SCH_DIC"
) -> pd.DataFrame:
    """
    Строит широкую таблицу с суммой показателя по каналам.

    Пример:
    value_col='GI_CNT_90', prefix='GI_CNT_90'
    -> GI_CNT_90_Federal, GI_CNT_90_Local ...
    """
    agg = (
        df.groupby([row_id_col, channel_col], as_index=False)
        .agg(VALUE=(value_col, "sum"))
    )

    agg["COL_NAME"] = agg[channel_col].apply(
        lambda x: f"{prefix}_{clean_channel_name(x)}"
    )

    return (
        agg.pivot(index=row_id_col, columns="COL_NAME", values="VALUE")
        .reset_index()
    )

def pivot_pos_by_flag_and_channel(
    df: pd.DataFrame,
    row_id_col: str = "POI_ROW_ID",
    flag_col: str = "FLAG_GI_90",
    channel_col: str = "SCH_DIC",
    pos_id_col: str = "POS_ID"
) -> pd.DataFrame:
    """
    Строит широкую таблицу с количеством POS по каналам и признаку продаж.

    Пример выходных колонок:
    - POS_COUNT_SELL_Federal
    - POS_COUNT_NOT_SELL_Local
    """
    agg = (
        df.groupby([row_id_col, flag_col, channel_col], as_index=False)
        .agg(POS_COUNT=(pos_id_col, "nunique"))
    )

    agg["COL_NAME"] = agg.apply(
        lambda row: (
            f"POS_COUNT_"
            f"{'SELL' if row[flag_col] == 1 else 'NOT_SELL'}_"
            f"{clean_channel_name(row[channel_col])}"
        ),
        axis=1
    )

    return (
        agg.pivot(index=row_id_col, columns="COL_NAME", values="POS_COUNT")
        .reset_index()
    )

def ensure_columns(df: pd.DataFrame, cols: list[str], fill_value=0) -> pd.DataFrame:
    """
    Добавляет в DataFrame недостающие колонки с указанным значением по умолчанию.
    """
    out = df.copy()
    for col in cols:
        if col not in out.columns:
            out[col] = fill_value
    return out

def pivot_metric_by_flag(
    df: pd.DataFrame,
    value_col: str,
    prefix: str,
    row_id_col: str = "POI_ROW_ID",
    flag_col: str = "FLAG_GI_90"
) -> pd.DataFrame:
    """
    Строит pivot по признаку продающая / не продающая.

    Пример:
    value_col='POS_ID' + nunique -> POS_COUNT_SELL / POS_COUNT_NOT_SELL
    """
    agg = (
        df.groupby([row_id_col, flag_col], as_index=False)
        .agg(VALUE=(value_col, "nunique"))
    )

    pivot = (
        agg.pivot(index=row_id_col, columns=flag_col, values="VALUE")
        .reset_index()
        .rename(columns={
            0: f"{prefix}_NOT_SELL",
            1: f"{prefix}_SELL"
        })
    )

    return ensure_columns(
        pivot,
        [f"{prefix}_SELL", f"{prefix}_NOT_SELL"],
        fill_value=0
    )

def to_numeric_series(series: pd.Series) -> pd.Series:
    """
    Приводит Series к числовому типу.
    Поддерживает числа в строковом формате и замену запятой на точку.
    Некорректные значения превращаются в NaN.
    """
    return pd.to_numeric(
        series.astype(str).str.replace(",", ".", regex=False).str.strip(),
        errors="coerce"
    )

def clean_channel_name(value: str) -> str:
    """
    Очищает название канала продаж для безопасного использования в названии колонки.
    Например:
    'On-line' -> 'On_line'
    'Federal / X' -> 'Federal___X'
    """
    return (
        str(value)
        .strip()
        .replace(" ", "_")
        .replace("/", "_")
        .replace("\\", "_")
        .replace("-", "_")
    )

def add_geometry_from_lon_lat(
    df: pd.DataFrame,
    lon_col: str = "LON",
    lat_col: str = "LAT",
    source_crs: str = "EPSG:4326",
    target_crs: str | None = None
) -> gpd.GeoDataFrame:
    """
    Создает GeoDataFrame из DataFrame по колонкам долготы и широты.

    Параметры:
    - df: исходный DataFrame
    - lon_col, lat_col: названия колонок с координатами
    - source_crs: исходная система координат
    - target_crs: если указана, выполняется перепроекция

    Возвращает:
    - GeoDataFrame
    """
    out = df.copy()
    out[lon_col] = to_numeric_series(out[lon_col])
    out[lat_col] = to_numeric_series(out[lat_col])
    out = out[out[lon_col].notna() & out[lat_col].notna()].copy()

    gdf = gpd.GeoDataFrame(
        out,
        geometry=gpd.points_from_xy(out[lon_col], out[lat_col]),
        crs=source_crs
    )

    if target_crs:
        gdf = gdf.to_crs(target_crs)

    return gdf

def build_poi_pos_metrics(
    df_poi_loc_adm: pd.DataFrame,
    df_pos_filtered: pd.DataFrame,
    buffer_meters: int = 300) -> gpd.GeoDataFrame:
    """
    Строит итоговый GeoDataFrame POI с метриками по POS в буфере.

    Что считается:
    - POS_COUNT_ALL
    - POS_COUNT_SELL / POS_COUNT_NOT_SELL
    - POS_COUNT_SELL_<канал> / POS_COUNT_NOT_SELL_<канал>
    - GI_CNT_90_ALL
    - GI_CNT_90_<канал>

    Важно:
    - GI считается только для продающих точек FLAG_GI_90 = 1
    """
    gdf_poi = add_geometry_from_lon_lat(
        df_poi_loc_adm,
        lon_col="LON",
        lat_col="LAT",
        source_crs="EPSG:4326",
        target_crs="EPSG:32637"
    )

    gdf_poi["BUFFER"] = gdf_poi.geometry.buffer(buffer_meters)
    gdf_poi = gdf_poi.reset_index(drop=True)
    gdf_poi["POI_ROW_ID"] = gdf_poi.index

    gdf_buffers = gpd.GeoDataFrame(
        gdf_poi[["POI_ROW_ID", "BUFFER"]].copy(),
        geometry="BUFFER",
        crs=gdf_poi.crs
    )

    gdf_pos = add_geometry_from_lon_lat(
        df_pos_filtered,
        lon_col="LON",
        lat_col="LAT",
        source_crs="EPSG:4326",
        target_crs="EPSG:32637"
    )

    gdf_pos["FLAG_GI_90"] = gdf_pos["FLAG_GI_90"].fillna(0).astype(int)
    gdf_pos["SCH_DIC"] = gdf_pos["SCH_DIC"].fillna("UNKNOWN").astype(str).str.strip()
    gdf_pos["POS_ID"] = gdf_pos["POS_ID"].astype(str)
    gdf_pos["GI_CNT_90"] = to_numeric_series(gdf_pos["GI_CNT_90"]).fillna(0)

    df_join = gpd.sjoin(
        gdf_buffers,
        gdf_pos[["POS_ID", "FLAG_GI_90", "SCH_DIC", "GI_CNT_90", "geometry"]],
        how="left",
        predicate="contains"
    )

    df_join_notnull = df_join[df_join["POS_ID"].notna()].copy()
    df_join_sell = df_join_notnull[df_join_notnull["FLAG_GI_90"] == 1].copy()

    agg_total = (
        df_join_notnull
        .groupby("POI_ROW_ID", as_index=False)
        .agg(POS_COUNT_ALL=("POS_ID", "nunique"))
    )

    pivot_flag = pivot_metric_by_flag(
        df_join_notnull,
        value_col="POS_ID",
        prefix="POS_COUNT"
    )

    pivot_flag_sch = pivot_pos_by_flag_and_channel(df_join_notnull)

    agg_gi_total = (
        df_join_sell
        .groupby("POI_ROW_ID", as_index=False)
        .agg(GI_CNT_90_ALL=("GI_CNT_90", "sum"))
    )

    pivot_gi_sch_total = pivot_sum_by_channel(
        df_join_sell,
        value_col="GI_CNT_90",
        prefix="GI_CNT_90"
    )

    gdf_poi = gdf_poi.merge(agg_total, on="POI_ROW_ID", how="left")
    gdf_poi = gdf_poi.merge(pivot_flag, on="POI_ROW_ID", how="left")
    gdf_poi = gdf_poi.merge(agg_gi_total, on="POI_ROW_ID", how="left")
    gdf_poi = gdf_poi.merge(pivot_gi_sch_total, on="POI_ROW_ID", how="left")
    gdf_poi = gdf_poi.merge(pivot_flag_sch, on="POI_ROW_ID", how="left")

    gdf_poi = fill_metric_columns(gdf_poi, prefixes=("POS_COUNT_", "GI_CNT_90_"))

    gdf_poi.drop(columns=["POI_ROW_ID"], inplace=True)
    gdf_poi = gdf_poi.to_crs("EPSG:4326")

    return gdf_poi

def kml_polygons_from_zip(path_poi_circle: str, wanted_files) -> gpd.GeoDataFrame:
    """
    Читает указанные KML-файлы из zip-архива и возвращает GeoDataFrame
    с колонками:
    - ID
    - MULTIPOLYGON_WKT
    - source_file

    Логика:
    1. В архиве ищутся только нужные KML по имени файла
    2. Оставляются только Polygon / MultiPolygon
    3. Все геометрии приводятся к WGS84
    4. Polygon конвертируется в MultiPolygon
    """
    wanted_set = {Path(name).name for name in wanted_files}
    rows = []

    with zipfile.ZipFile(path_poi_circle, "r") as z, tempfile.TemporaryDirectory() as tdir:
        name_in_zip_by_basename = {}

        for member in z.namelist():
            if member.lower().endswith(".kml") and not member.endswith("/"):
                base = Path(member).name
                name_in_zip_by_basename.setdefault(base, member)

        existing = {fn for fn in wanted_set if fn in name_in_zip_by_basename}
        missing = sorted(wanted_set - existing)

        if missing:
            print("⚠️ В архиве не найдены файлы:", ", ".join(missing))

        for base_name in sorted(existing):
            member = name_in_zip_by_basename[base_name]
            extract_path = Path(tdir) / base_name

            with z.open(member) as src, open(extract_path, "wb") as dst:
                dst.write(src.read())

            try:
                gdf = gpd.read_file(str(extract_path), driver="KML")
            except Exception as e:
                print(f"❌ Ошибка чтения {base_name}: {e}")
                continue

            if gdf.empty:
                continue

            gdf = gdf[gdf.geometry.notna()]
            gdf = gdf[gdf.geometry.geom_type.isin(["Polygon", "MultiPolygon"])]

            if gdf.empty:
                continue

            if gdf.crs is None:
                gdf.set_crs(epsg=4326, inplace=True)
            else:
                gdf = gdf.to_crs(epsg=4326)

            def as_multipolygon(geom):
                if geom.geom_type == "Polygon":
                    return MultiPolygon([geom])
                return geom

            gdf["multipolygon"] = gdf.geometry.apply(as_multipolygon)
            gdf["MULTIPOLYGON_WKT"] = gdf["multipolygon"].apply(dumps)
            gdf["source_file"] = base_name

            rows.append(gdf[["MULTIPOLYGON_WKT", "source_file"]])

    if not rows:
        return gpd.GeoDataFrame(columns=["ID", "MULTIPOLYGON_WKT", "source_file"])

    out = pd.concat(rows, ignore_index=True)
    out.insert(0, "ID", range(1, len(out) + 1))
    return gpd.GeoDataFrame(out)


def build_polygon_circle_gdf(
    path_poi_circle: str,
    reg_files
) -> gpd.GeoDataFrame:
    """
    Один раз читает архив с KML и строит GeoDataFrame полигонов.
    """
    gdf_out = kml_polygons_from_zip(path_poi_circle, reg_files)

    if gdf_out.empty:
        return gpd.GeoDataFrame(
            columns=["ID", "MULTIPOLYGON_WKT", "source_file", "geometry"],
            crs="EPSG:4326"
        )

    df_polygon_circle = gdf_out[["ID", "MULTIPOLYGON_WKT", "source_file"]].copy()
    df_polygon_circle["geometry"] = gpd.GeoSeries.from_wkt(df_polygon_circle["MULTIPOLYGON_WKT"])

    return gpd.GeoDataFrame(df_polygon_circle, geometry="geometry", crs="EPSG:4326")


def add_polygon_counts_from_gdf(
    gdf_poi: gpd.GeoDataFrame,
    gdf_polygon_circle: gpd.GeoDataFrame
) -> gpd.GeoDataFrame:
    """
    Для каждой точки POI считает количество полигонов, которые ее покрывают.
    """
    out = gdf_poi.copy()

    if gdf_polygon_circle.empty:
        out["polygon_count"] = 0
        return out

    sindex = gdf_polygon_circle.sindex

    def count_polygons_containing_point(point):
        if point is None or point.is_empty:
            return 0

        possible_idx = list(sindex.intersection(point.bounds))
        possible = gdf_polygon_circle.iloc[possible_idx]

        return possible["geometry"].covers(point).sum()

    out["polygon_count"] = out["geometry"].apply(count_polygons_containing_point)

    return out


