def create_legend_png(output_path):
    legend_lines = [
        "Качество связи в тайле:",
        "• комплексный расчетный показатель от CEM на основе данных VK",
        "  по совокупности метрик: доля LTE в тайле,",
        "  доля быстрой загрузки в тайле",
        "",
        "RSRQ:",
        "• показатель качества сигнала LTE. Чем ближе значение к 0,",
        "  тем лучше качество связи.",
        "",
        "Разбивка RSRQ:",
        "• Deep Indoor — глубокий indoor (от 0 до -5)",
        "• Indoor — внутри помещений (от -5 до -10)",
        "• In Car — в транспорте (от -10 до -15)",
        "• Outdoor — на улице (от -15 до -20)",
        "",
        "Типы сайтов:",
        "• Превалирующий — сайт, где абонент потребил >50% трафика",
        "  за отчетный месяц",
        "• Домашний — сайт, где абонент чаще всего находился ночью",
        "  за отчетный месяц",
        "• Рабочий — сайт, где абонент чаще всего был в будние дни",
        "  днем за отчетный месяц",
        "• Развлекательный — сайт, где абонент чаще всего был",
        "  в выходные за отчетный месяц",
        "",
        "Схема тайлов:",
    ]

    width = 820
    padding = 20
    line_h = 26
    scheme_height = 130
    bottom_extra = 24
    height = padding * 2 + line_h * len(legend_lines) + scheme_height + bottom_extra

    img = Image.new("RGBA", (width, height), (255, 255, 255, 0))
    draw = ImageDraw.Draw(img)

    panel_color = (10, 10, 10, 185)
    border_color = (255, 255, 255, 180)
    text_color = (245, 245, 245, 255)
    section_color = (170, 220, 255, 255)

    color_neighbor = (255, 120, 160, 235)
    color_center = (90, 215, 120, 245)
    color_grid = (255, 255, 255, 230)

    draw.rounded_rectangle(
        [(0, 0), (width - 1, height - 1)],
        radius=16,
        fill=panel_color,
        outline=border_color,
        width=2
    )

    try:
        font_text = ImageFont.truetype("arial.ttf", 20)
        font_section = ImageFont.truetype(r"C:\Windows\Fonts\tahomabd.ttf", 20)
    except Exception:
        font_text = ImageFont.load_default()
        font_section = ImageFont.load_default()

    y = padding
    for line in legend_lines:
        if line.endswith(":") and line != "":
            draw.text((padding, y), line, font=font_section, fill=section_color)
        else:
            draw.text((padding, y), line, font=font_text, fill=text_color)
        y += line_h

    scheme_top = y + 10
    cell = 42
    gap = 4

    grid_x = padding + 12
    grid_y = scheme_top + 8

    sample_x = grid_x + 3 * (cell + gap) + 80
    sample_y1 = grid_y + 8
    sample_y2 = sample_y1 + 52
    box_w = 72
    box_h = 28

    for r in range(3):
        for c in range(3):
            x1 = grid_x + c * (cell + gap)
            y1 = grid_y + r * (cell + gap)
            x2 = x1 + cell
            y2 = y1 + cell

            fill = color_neighbor
            if r == 1 and c == 1:
                fill = color_center

            draw.rounded_rectangle(
                [(x1, y1), (x2, y2)],
                radius=4,
                fill=fill,
                outline=color_grid,
                width=2
            )

    draw.rounded_rectangle(
        [(sample_x, sample_y1), (sample_x + box_w, sample_y1 + box_h)],
        radius=5,
        fill=color_center,
        outline=color_grid,
        width=2
    )
    draw.text(
        (sample_x + box_w + 16, sample_y1 + 3),
        "Тайл нахождения POI",
        font=font_text,
        fill=(255, 255, 255, 255)
    )

    draw.rounded_rectangle(
        [(sample_x, sample_y2), (sample_x + box_w, sample_y2 + box_h)],
        radius=5,
        fill=color_neighbor,
        outline=color_grid,
        width=2
    )
    draw.text(
        (sample_x + box_w + 16, sample_y2 + 3),
        "Соседние тайлы",
        font=font_text,
        fill=(255, 255, 255, 255)
    )

    img.save(output_path)


def add_screen_legend(kml_obj, legend_img_name="legend.png", position="bottomleft"):
    """
    Добавляет легенду как screen overlay внутрь KML.
    legend_img_name — имя файла внутри KMZ.
    """
    legend = kml_obj.newscreenoverlay(name="Легенда")
    legend.icon.href = legend_img_name

    if position == "bottomleft":
        screen_x, screen_y = 0.02, 0.05
        overlay_x, overlay_y = 0, 0
    elif position == "bottomright":
        screen_x, screen_y = 0.98, 0.05
        overlay_x, overlay_y = 1, 0
    elif position == "topleft":
        screen_x, screen_y = 0.02, 0.98
        overlay_x, overlay_y = 0, 1
    else:
        screen_x, screen_y = 0.98, 0.98
        overlay_x, overlay_y = 1, 1

    legend.overlayxy = simplekml.OverlayXY(
        x=overlay_x,
        y=overlay_y,
        xunits=simplekml.Units.fraction,
        yunits=simplekml.Units.fraction
    )

    legend.screenxy = simplekml.ScreenXY(
        x=screen_x,
        y=screen_y,
        xunits=simplekml.Units.fraction,
        yunits=simplekml.Units.fraction
    )

    legend.size.x = 500
    legend.size.y = 0
    legend.size.xunits = simplekml.Units.pixels
    legend.size.yunits = simplekml.Units.pixels


