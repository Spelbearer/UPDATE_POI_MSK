# 5. ПОСТРОЕНИЕ СЛОЕВ
# =========================================================
def add_poi_layer(kml, df_poi, config):
    if df_poi is None or df_poi.empty:
        return

    folder = kml.newfolder(name=config["poi_folder_name"])

    for _, row in df_poi.iterrows():
        try:
            lat = get_row_float(row, "LAT")
            lon = get_row_float(row, "LON")

            if lat is None or lon is None:
                continue

            osm_id = safe_str(get_row_value(row, "OSM_ID"))
            point_name = config["poi_name_template"].format(OSM_ID=osm_id)

            point = folder.newpoint(
                name=point_name,
                coords=[(float(lon), float(lat))]
            )

            apply_point_style(
                point=point,
                icon_href=config["poi_icon_href"],
                icon_scale=config["poi_icon_scale"],
                label_scale=config["poi_label_scale"]
            )

            point.description = build_poi_description(row)

        except Exception as e:
            print(f"Ошибка при обработке POI OSM_ID={row.get('OSM_ID', 'UNKNOWN')}: {e}")
            continue


def add_pos_layer(kml, df_pos, config):
    if df_pos is None or df_pos.empty:
        return

    pos_root = kml.newfolder(name=config["pos_root_folder_name"])
    pos_root.visibility = config.get("pos_root_visibility", 0)
    pos_root.open = 0

    folder_sell = pos_root.newfolder(name=config["pos_sell_folder_name"])
    folder_sell.visibility = config.get("pos_root_visibility", 0)
    folder_sell.open = 0

    folder_not_sell = pos_root.newfolder(name=config["pos_not_sell_folder_name"])
    folder_not_sell.visibility = config.get("pos_root_visibility", 0)
    folder_not_sell.open = 0

    for _, row in df_pos.iterrows():
        try:
            lat = get_row_float(row, "LAT")
            lon = get_row_float(row, "LON")

            if lat is None or lon is None:
                continue

            pos_id = safe_str(get_row_value(row, "POS_ID"))
            flag_gi_90 = get_row_float(row, "FLAG_GI_90")
            is_sell = int(flag_gi_90 or 0) == 1

            target_folder = folder_sell if is_sell else folder_not_sell

            point_name = config["pos_name_template"].format(POS_ID=pos_id)

            point = target_folder.newpoint(
                name=point_name,
                coords=[(float(lon), float(lat))]
            )

            point.visibility = config.get("pos_root_visibility", 0)

            apply_point_style(
                point=point,
                icon_href=config["pos_sell_icon_href"] if is_sell else config["pos_not_sell_icon_href"],
                icon_scale=config["pos_icon_scale"],
                label_scale=config["pos_label_scale"]
            )

            point.description = build_pos_description(row)

        except Exception as e:
            print(f"Ошибка при обработке POS_ID={row.get('POS_ID', 'UNKNOWN')}: {e}")
            continue


# =========================================================
# 6. СОХРАНЕНИЕ
# =========================================================
def save_kml_or_kmz(kml, output_path, legend_png_path=None):
    """
    Сохраняет KML/KMZ.
    
    Если output_path заканчивается на .kmz:
    - создает временный doc.kml
    - при наличии legend_png_path кладет legend.png внутрь архива
    - собирает KMZ вручную

    Если output_path заканчивается на .kml:
    - сохраняет обычный KML
    """
    if output_path.lower().endswith(".kmz"):
        import tempfile
        import zipfile
        from pathlib import Path

        with tempfile.TemporaryDirectory() as tmpdir:
            tmpdir = Path(tmpdir)

            doc_kml_path = tmpdir / "doc.kml"
            kml.save(str(doc_kml_path))

            with zipfile.ZipFile(output_path, "w", compression=zipfile.ZIP_DEFLATED) as zf:
                zf.write(doc_kml_path, arcname="doc.kml")

                if legend_png_path and os.path.exists(legend_png_path):
                    zf.write(legend_png_path, arcname="legend.png")
    else:
        kml.save(output_path)


