def get_latest_month_mask(series: pd.Series, fmt: str = "%d.%m.%Y") -> pd.Series:
    """
    Возвращает булеву маску для строк, относящихся к последнему месяцу в Series.
    """
    dt = pd.to_datetime(series, format=fmt)
    return dt.dt.to_period("M") == dt.dt.to_period("M").max()

def load_input_data(
    path_msh: str,
    path_pos: str,
    path_poi: str,
    path_reg: str,
    path_cat: str,
    sheet_name_reg: str,
    sheet_name_cat: str
) -> tuple[pd.DataFrame, pd.DataFrame, pd.DataFrame, pd.DataFrame, pd.DataFrame]:
    """
    Загружает исходные данные из txt/xlsx файлов.

    Возвращает:
    - df_msh
    - df_pos
    - df_poi
    - df_reg
    - df_cat
    """
    df_msh = pd.read_csv(path_msh, sep=";", encoding="utf-8")
    df_pos = pd.read_csv(path_pos, sep=";", encoding="utf-8")
    df_poi = pd.read_csv(path_poi, sep=";", encoding="utf-8")
    df_reg = pd.read_excel(path_reg, sheet_name=sheet_name_reg)
    df_cat = pd.read_excel(path_cat, sheet_name=sheet_name_cat)

    return df_msh, df_pos, df_poi, df_reg, df_cat


def filter_reference_regions(df_reg: pd.DataFrame, macro_id: int) -> pd.DataFrame:
    """
    Фильтрует справочник регионов по макрорегиону и признаку FLAG=True.
    """
    return df_reg[
        (df_reg["MACROREGION_ID"] == int(macro_id)) &
        (df_reg["FLAG"] == True)
    ].copy()


def prepare_filtered_inputs(
    df_msh: pd.DataFrame,
    df_pos: pd.DataFrame,
    df_poi: pd.DataFrame,
    df_reg_filtered: pd.DataFrame
) -> tuple[pd.DataFrame, pd.DataFrame, pd.DataFrame, np.ndarray]:
    """
    Готовит отфильтрованные таблицы:
    - MSH по последнему месяцу и нужным регионам
    - POS по последнему месяцу, активным точкам и нужным регионам
    - POI по нужным регионам POI
    - список имен файлов KML для кругов
    """
    reg_edw = df_reg_filtered["EDW"].dropna().unique()
    reg_files = df_reg_filtered.loc[
        df_reg_filtered["FILE_NAME"].str[:3] != "poi",
        "FILE_NAME"
    ].dropna().unique()

    df_msh_filtered = df_msh[
        (df_msh["LEVEL_MSK"].notna()) &
        (df_msh["LEVEL_MSK"] != 0) &
        get_latest_month_mask(df_msh["REPORT_DATE"])
    ].copy().drop(columns=
        ['ADMIN_REGION_NAME',
        'ADMIN_REGION_ID',
        'MARKET_SUBS_ADM',
        'MSH_HOME_ADM',
        'HOME_SUBS_ADM',
        'MSH_WORK_ADM',
        'WORK_SUBS_ADM',
        'MSH_EXTRAIN_ADM',
        'ENTRTAIN_SUBS_ADM',
        'SUBS_CNT_PREV_ADM',
        'MARKET_SHARE_PREV_ADM'])

    df_pos_filtered = df_pos[
        (df_pos["POS_STATUS_ID"] == 1) &
        df_pos["REGION_NAME"].isin(reg_edw) &
        get_latest_month_mask(df_pos["REPORT_MONTH"])
    ].drop(columns=["POS_STATUS_ID", "MACROREGION_ID", "MACROREGION_NAME", "REGION_ID"], errors="ignore").copy()

    df_poi_filtered = df_poi[df_poi["LEVEL_MSC"]!='0,0'].copy().drop(columns=
        ['MACROREGION_NAME',
        'REGION_NAME_EDW',
        'ADMIN_REGION_NAME',
        'ADMIN_REGION_ID',
        'TILE_ID',
        'NEIGHBOR_TILE_IDS',
        'MAX_DATE_POTENCIAL']
    )

    return df_msh_filtered, df_pos_filtered, df_poi_filtered, reg_files

