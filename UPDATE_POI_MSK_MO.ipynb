# 2. ВСПОМОГАТЕЛЬНЫЕ ФУНКЦИИ
# =========================================================
def safe_val(v):
    """
    Возвращает значение без NaN.

    Что делает:
        - если значение пустое/NaN -> возвращает пустую строку
        - иначе возвращает само значение как есть

    Для чего нужна:
        Чтобы в описании KML не появлялись 'nan'.
    """
    if pd.isna(v):
        return ""
    return v


def safe_str(v):
    """
    Безопасно преобразует значение в строку.

    Что делает:
        - если значение NaN -> возвращает ""
        - иначе str(v)

    Для чего нужна:
        Для формирования имени точки, описания, ID и текстовых полей.
    """
    if pd.isna(v):
        return ""
    return str(v)


def safe_date(v):
    """
    Приводит дату к строке формата YYYY-MM-DD.

    Что делает:
        - если значение пустое -> ""
        - если дата распознается -> форматирует как YYYY-MM-DD
        - если не удалось распарсить -> возвращает исходное значение строкой

    Для чего нужна:
        Чтобы дата в описании выглядела одинаково и аккуратно.
    """
    if pd.isna(v):
        return ""
    try:
        return pd.to_datetime(v, dayfirst=True).strftime("%Y-%m-%d")
    except Exception:
        return str(v)


def to_float_safe(v):
    """
    Безопасно преобразует значение в float.

    Что делает:
        - NaN / пустая строка -> None
        - строки вида '12,5%' -> 12.5
        - строки с пробелами -> очищает
        - если преобразование невозможно -> None

    Для чего нужна:
        Для последующего форматирования процентов, чисел и координат.
    """
    if pd.isna(v) or v == "":
        return None
    try:
        if isinstance(v, str):
            v = v.strip().replace(" ", "").replace("%", "").replace(",", ".")
        return float(v)
    except Exception:
        return None


def safe_filename(value):
    """
    Очищает строку для безопасного использования в имени файла.

    Что делает:
        - если значение пустое -> UNKNOWN
        - удаляет запрещенные символы Windows
        - заменяет пробелы на _
    """
    if pd.isna(value):
        return "UNKNOWN"

    value = str(value).strip()

    for ch in r'<>:"/\|?*':
        value = value.replace(ch, "_")

    value = value.replace(" ", "_")
    return value


def fmt_percent_from_share(v, digits=1):
    """
    Форматирует долю в процент.

    Ожидает:
        Значение в формате доли, например:
        0.153 -> 15,3%

    Возвращает:
        Строку вида '15,3%' или '-'
    """
    val = to_float_safe(v)
    if val is None:
        return "-"
    return f"{val * 100:.{digits}f}%".replace(".", ",")


def fmt_percent_ready(v, digits=1):
    """
    Форматирует уже готовый процент.

    Ожидает:
        Значение в процентах, например:
        15.3 -> 15,3%

    Возвращает:
        Строку вида '15,3%' или '-'
    """
    val = to_float_safe(v)
    if val is None:
        return "-"
    return f"{val:.{digits}f}%".replace(".", ",")


def fmt_int_spaces(v):
    """
    Форматирует число как целое с пробелами между тысячами.

    Пример:
        12345 -> '12 345'

    Возвращает:
        Строку или '-'
    """
    val = to_float_safe(v)
    if val is None:
        return "-"
    return f"{int(round(val)):,}".replace(",", " ")


def fmt_decimal_spaces(v, digits=2):
    """
    Форматирует десятичное число с пробелами между тысячами
    и запятой как десятичным разделителем.

    Пример:
        12345.67 -> '12 345,67'

    Возвращает:
        Строку или '-'
    """
    val = to_float_safe(v)
    if val is None:
        return "-"
    return f"{val:,.{digits}f}".replace(",", "X").replace(".", ",").replace("X", " ")


def fmt_flag_gi(v):
    """
    Преобразует флаг продающей точки в текст.

    Логика:
        1 -> 'Продающая'
        0 -> 'Не продающая'
        None/пусто -> '-'
    """
    val = to_float_safe(v)
    if val is None:
        return "-"
    return "Продающая" if int(val) == 1 else "Не продающая"


def get_row_value(row, col_name, default=""):
    """
    Безопасно читает поле из строки DataFrame.

    Что делает:
        - если колонки нет -> default
        - если есть -> safe_val(row[col_name])

    Для чего нужна:
        Чтобы код не падал, если какого-то поля нет в датафрейме.
    """
    if col_name not in row.index:
        return default
    return safe_val(row[col_name])


def get_row_float(row, col_name):
    """
    Безопасно читает поле из строки DataFrame и приводит к float.

    Возвращает:
        float или None
    """
    if col_name not in row.index:
        return None
    return to_float_safe(row[col_name])


def apply_point_style(point, icon_href, icon_scale=1.0, label_scale=0):
    """
    Применяет стиль к точке KML.
    """
    point.style.labelstyle.scale = label_scale
    point.style.iconstyle.scale = icon_scale
    point.style.iconstyle.icon.href = icon_href


