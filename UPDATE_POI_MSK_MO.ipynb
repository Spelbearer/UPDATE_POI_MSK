def make_combined_kmz(df_poi=None, df_pos=None, config=None):
    """
    Формирует итоговый KML/KMZ.
    Легенда для KMZ создается временно и упаковывается внутрь архива.
    На диске отдельно не остается.
    """
    import tempfile

    final_config = DEFAULT_KML_CONFIG.copy()
    if config:
        final_config.update(config)

    if "output_path" not in final_config or not final_config["output_path"]:
        raise ValueError("В config не передан output_path")

    output_path = final_config["output_path"]
    output_dir = os.path.dirname(output_path)

    if output_dir and not os.path.exists(output_dir):
        os.makedirs(output_dir, exist_ok=True)

    kml = simplekml.Kml()

    if final_config["build_poi_layer"]:
        add_poi_layer(kml=kml, df_poi=df_poi, config=final_config)

    if final_config["build_pos_layer"]:
        add_pos_layer(kml=kml, df_pos=df_pos, config=final_config)

    temp_legend_path = None

    try:
        if final_config.get("add_legend", False):
            with tempfile.NamedTemporaryFile(suffix=".png", delete=False) as tmp:
                temp_legend_path = tmp.name

            create_legend_png(temp_legend_path)

            # В KML ссылка будет на legend.png внутри KMZ
            add_screen_legend(
                kml_obj=kml,
                legend_img_name="legend.png",
                position=final_config["legend_position"]
            )

        save_kml_or_kmz(
            kml=kml,
            output_path=output_path,
            legend_png_path=temp_legend_path
        )

        print(f"Готово. Файл сохранен: {output_path}")
        return output_path

    finally:
        if temp_legend_path and os.path.exists(temp_legend_path):
            try:
                os.remove(temp_legend_path)
            except Exception:
                pass


# =========================================================
# 8. ВЫГРУЗКА KMZ ПО КАЖДОМУ РЕГИОНУ
# =========================================================
def export_region_kmz_files(
    df_poi,
    df_pos,
    path_oper_mr,
    file_kml_name_out="POI_",
    file_kml_ext=".kmz",
    base_config=None
):
    if df_poi is None or df_poi.empty:
        print("df_poi пустой, выгрузка KMZ не выполнена.")
        return []

    if "REGION_MSK" not in df_poi.columns:
        raise ValueError("В df_poi отсутствует колонка REGION_MSK")

    if df_pos is not None and not df_pos.empty and "REGION_NAME" not in df_pos.columns:
        raise ValueError("В df_pos отсутствует колонка REGION_NAME")

    output_dir = Path(path_oper_mr)
    output_dir.mkdir(parents=True, exist_ok=True)

    region_list = (
        df_poi["REGION_MSK"]
        .dropna()
        .astype(str)
        .str.strip()
        .drop_duplicates()
        .tolist()
    )

    saved_files = []

    for region_name in region_list:
        df_poi_region = df_poi[
            df_poi["REGION_MSK"].astype(str).str.strip() == region_name
        ].copy()

        if df_pos is not None and not df_pos.empty:
            df_pos_region = df_pos[
                df_pos["REGION_NAME"].astype(str).str.strip() == region_name
            ].copy()
        else:
            df_pos_region = None

        region_name_for_file = safe_filename(region_name)

        output_path = str(
            output_dir / f"{file_kml_name_out}{region_name_for_file}{file_kml_ext}"
        )

        region_config = DEFAULT_KML_CONFIG.copy()
        if base_config:
            region_config.update(base_config)

        region_config["output_path"] = output_path
        region_config["poi_folder_name"] = f"POI - {region_name}"
        region_config["pos_root_folder_name"] = f"POS - {region_name}"

        make_combined_kmz(
            df_poi=df_poi_region,
            df_pos=df_pos_region,
            config=region_config
        )

        saved_files.append(output_path)
        print(f"Выгружен KMZ по региону: {region_name} -> {output_path}")

    return saved_files

saved_kmz_files = export_region_kmz_files(
    df_poi=df_msh_poi_pos_rename_kml,
    df_pos=df_pos_filtered,
    path_oper_mr=path_oper_mr,
    file_kml_name_out=file_kml_name_out,
    file_kml_ext=file_kml_ext,
    base_config=DEFAULT_KML_CONFIG
)
